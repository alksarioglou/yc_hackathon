# Generated by `npx convex dev` — copy to .env.local
CONVEX_DEPLOYMENT=local:local-<your-deployment-name>
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210
NEXT_PUBLIC_CONVEX_SITE_URL=http://127.0.0.1:3211

# Google Maps JavaScript API — 3D Maps (enable Maps JavaScript API in Google Cloud)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Optional: Cesium ion token (alternative tile loading path)
NEXT_PUBLIC_CESIUM_ION_TOKEN=your_cesium_ion_token